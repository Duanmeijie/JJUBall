/* components/activity-card/activity-card.wxss */
/* "国球红" Design System */

.activity-card {
  position: relative;
  background: #ffffff;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card-hover {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* Top Accent Strip */
.accent-strip {
  height: 8rpx;
  width: 100%;
}

.accent-strip.accent-entertainment {
  background: linear-gradient(90deg, #34C759, #5DD87A);
}

.accent-strip.accent-internal {
  background: linear-gradient(90deg, #D4363C, #E85A5F);
}

.accent-strip.accent-external {
  background: linear-gradient(90deg, #FF6B35, #FF8F66);
}

/* Card Content */
.card-content {
  padding: 28rpx 28rpx 24rpx;
}

/* Title Row */
.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D3A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.type-tag {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}

.type-tag.type-entertainment {
  background: rgba(52, 199, 89, 0.12);
  color: #34C759;
}

.type-tag.type-internal {
  background: rgba(212, 54, 60, 0.10);
  color: #D4363C;
}

.type-tag.type-external {
  background: rgba(255, 107, 53, 0.12);
  color: #FF6B35;
}

/* Info Section */
.info-section {
  margin-bottom: 22rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-emoji {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 26rpx;
  color: #6B6B80;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.5;
}

/* Bottom Section */
.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.progress-section {
  flex: 1;
  margin-right: 24rpx;
}

.progress-bar-bg {
  width: 100%;
  height: 12rpx;
  background: #F0F0F5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #D4363C, #FF6B35);
  transition: width 0.3s ease;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-count {
  font-size: 22rpx;
  color: #6B6B80;
}

.progress-percent {
  font-size: 22rpx;
  color: #9E9EB0;
}

/* Bottom Right */
.bottom-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}

.status-badge.status-open {
  background: rgba(52, 199, 89, 0.12);
  color: #34C759;
}

.status-badge.status-closed {
  background: rgba(255, 149, 0, 0.12);
  color: #FF9500;
}

.status-badge.status-cancelled {
  background: rgba(158, 158, 176, 0.12);
  color: #9E9EB0;
}

.status-badge.status-completed {
  background: rgba(158, 158, 176, 0.12);
  color: #9E9EB0;
}

.arrow-indicator {
  font-size: 36rpx;
  color: #9E9EB0;
  margin-left: 12rpx;
  font-weight: 300;
}
