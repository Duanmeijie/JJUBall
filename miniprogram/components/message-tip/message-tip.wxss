/* components/message-tip/message-tip.wxss */
.message-tip {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  z-index: 100;
}

.tip-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #F44336;
  border-radius: 16rpx;
  border: 2rpx solid #ffffff;
  box-sizing: border-box;
}

.tip-badge.badge-large {
  min-width: 48rpx;
  padding: 0 10rpx;
}

.tip-count {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1;
}
