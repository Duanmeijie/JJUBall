.page-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Permission Notice */
.permission-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.notice-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.notice-text {
  font-size: 32rpx;
  color: #999;
  text-align: center;
}

/* Form Sections */
.record-form {
  padding-bottom: 60rpx;
}

.form-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* Player Cards */
.player-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  border: 2rpx dashed #ddd;
  transition: all 0.3s ease;
}

.player-card.selected {
  border: 2rpx solid #07c160;
  background-color: #f0faf4;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 2rpx solid #eee;
}

.player-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.placeholder-icon {
  font-size: 48rpx;
  color: #ccc;
}

.player-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* VS Divider */
.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0;
}

.vs-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b35;
  letter-spacing: 4rpx;
}

/* Picker Display */
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #eee;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* Form Input */
.form-input {
  padding: 24rpx 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  border: 2rpx solid #eee;
}

/* Score Section */
.score-section {
  margin-top: 40rpx;
  margin-bottom: 50rpx;
}

.score-input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.score-input-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-input {
  width: 160rpx;
  height: 120rpx;
  text-align: center;
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  border-bottom: 4rpx solid #07c160;
  line-height: 120rpx;
}

.score-colon {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  margin: 0 20rpx;
  padding-top: 40rpx;
}

/* Submit Button */
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 34rpx;
  font-weight: 500;
  border-radius: 48rpx;
  border: none;
  margin-top: 20rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[loading] {
  background-color: #88d4a8;
}
