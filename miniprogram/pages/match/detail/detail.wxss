.page-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Match Card */
.match-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* Players VS Section */
.players-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.player-info.winner {
  transform: scale(1.05);
}

.player-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.player-info.winner .player-avatar {
  border-color: #FFD700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.player-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.winner-badge {
  position: absolute;
  top: -10rpx;
  right: 10rpx;
  background-color: #FFD700;
  color: #333;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

/* Score Display */
.score-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
}

.score {
  font-size: 80rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.7);
  min-width: 80rpx;
  text-align: center;
}

.score.highlight {
  color: #FFD700;
  text-shadow: 0 2rpx 8rpx rgba(255, 215, 0, 0.4);
}

.score-separator {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 10rpx;
}

/* Detail Section */
.detail-section {
  padding: 40rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* Score Changes */
.score-changes {
  padding: 30rpx 40rpx 40rpx;
  border-top: 12rpx solid #f5f5f5;
}

.changes-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.changes-row {
  display: flex;
  justify-content: space-around;
}

.change-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  min-width: 200rpx;
}

.change-player {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.change-value {
  font-size: 40rpx;
  font-weight: bold;
}

.change-value.positive {
  color: #07c160;
}

.change-value.negative {
  color: #f56c6c;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
