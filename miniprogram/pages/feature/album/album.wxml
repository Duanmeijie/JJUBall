<view class="page-wrap">
  <view class="header-banner">
    <text class="header-title">📸 活动相册</text>
    <text class="header-sub">精彩瞬间，永久珍藏</text>
  </view>

  <view class="sticky-tabs">
    <view class="tab-inner">
      <view class="tab-item {{activeTab === 'albums' ? 'active' : ''}}" bindtap="switchTab" data-tab="albums">相册列表</view>
      <view class="tab-item {{activeTab === 'photos' ? 'active' : ''}}" bindtap="switchTab" data-tab="photos">最近照片</view>
    </view>
  </view>

  <block wx:if="{{activeTab === 'albums'}}">
    <view class="album-grid">
      <view class="album-card" wx:for="{{albums}}" wx:key="_id" bindtap="viewAlbum" data-id="{{item._id}}">
        <view class="album-cover">
          <text class="album-cover-emoji">📷</text>
        </view>
        <view class="album-info">
          <text class="album-title">{{item.title || '未命名相册'}}</text>
          <text class="album-meta">{{item.photoCount || 0}} 张照片</text>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{albums.length === 0 && !loading}}">暂无相册</view>
    </view>
  </block>

  <block wx:if="{{activeTab === 'photos'}}">
    <view class="photo-masonry">
      <view class="photo-item" wx:for="{{photos}}" wx:key="_id" bindtap="viewPhotoDetail" data-id="{{item._id}}">
        <view class="photo-thumb" style="height: {{item.height || 240}}rpx">
          <text class="photo-emoji">🏓</text>
        </view>
        <view class="photo-overlay">
          <text class="photo-likes">❤️ {{item.likeCount || 0}}</text>
        </view>
      </view>
      <view class="empty-tip" wx:if="{{photos.length === 0 && !loading}}">暂无照片</view>
    </view>
  </block>

  <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
</view>
