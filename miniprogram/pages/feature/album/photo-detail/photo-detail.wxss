.page-wrap {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 60rpx;
}

.photo-main {
  background: #1A1A2E;
  min-height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-placeholder {
  text-align: center;
}

.photo-placeholder-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.photo-placeholder-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
}

.photo-actions {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 28rpx 0;
  background: #fff;
  margin-bottom: 4rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: #F5F5F8;
  border-radius: 20rpx;
}

.action-btn:active { opacity: 0.7; }

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #2D2D3A;
  font-weight: 500;
}

.action-count {
  font-size: 22rpx;
  color: #9E9EB0;
  margin-left: 6rpx;
}

.comment-section {
  background: #fff;
  padding: 28rpx;
  margin-top: 4rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-lbl {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D3A;
}

.comment-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F8;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.comment-submit {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #D4363C, #FF6B35);
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F8;
}

.comment-user {
  font-size: 24rpx;
  color: #D4363C;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.comment-content {
  font-size: 26rpx;
  color: #2D2D3A;
  display: block;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #9E9EB0;
}
