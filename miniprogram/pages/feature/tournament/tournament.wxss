.page-wrap {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 60rpx;
}

.header-banner {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  padding: 60rpx 36rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.tournament-list {
  padding: 0 28rpx;
}

.tournament-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.tournament-top {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.tournament-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  line-height: 1;
}

.tournament-info {
  flex: 1;
}

.tournament-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D3A;
  display: block;
  margin-bottom: 4rpx;
}

.tournament-desc {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
}

.tournament-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F8;
}

.tournament-status {
  font-size: 22rpx;
  color: #9E9EB0;
}

.tournament-status.ongoing {
  color: #2ECC71;
}

.bracket-open-btn {
  font-size: 26rpx;
  color: #2ECC71;
  font-weight: 600;
  padding: 12rpx 24rpx;
  background: rgba(46,204,113,0.1);
  border-radius: 16rpx;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 60rpx;
  font-size: 26rpx;
  color: #9E9EB0;
}

.bracket-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.bracket-header {
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  padding: 40rpx 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bracket-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.bracket-close {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
}

.bracket-scroll {
  flex: 1;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 40rpx 0;
}

.bracket-container {
  display: flex;
  align-items: center;
  height: 100%;
  padding: 0 40rpx;
  min-width: min-content;
}

.bracket-round {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  margin-right: 40rpx;
}

.round-label {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.bracket-match {
  background: rgba(255,255,255,0.95);
  border-radius: 16rpx;
  padding: 20rpx;
  min-width: 240rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.match-player {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 8rpx;
}

.match-player:first-child {
  border-bottom: 1rpx solid #F0F0F5;
}

.match-player.winner {
  background: rgba(46,204,113,0.08);
  border-radius: 8rpx;
}

.player-name {
  font-size: 24rpx;
  color: #2D2D3A;
  font-weight: 500;
}

.player-name.empty {
  color: #ccc;
}

.player-score {
  font-size: 24rpx;
  font-weight: 700;
  color: #D4363C;
}

.match-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-tip-bracket {
  color: rgba(255,255,255,0.6);
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
}
