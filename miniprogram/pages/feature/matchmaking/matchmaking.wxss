.page-wrap {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 60rpx;
}

.header-banner {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  padding: 60rpx 36rpx 100rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.my-score-card {
  margin: -60rpx 28rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 2;
}

.my-score-label {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-bottom: 8rpx;
}

.my-score-val {
  font-size: 56rpx;
  font-weight: 800;
  color: #667EEA;
  display: block;
  line-height: 1.2;
}

.my-score-rank {
  font-size: 24rpx;
  color: #764BA2;
  display: block;
  margin-top: 4rpx;
  font-weight: 500;
}

.match-tabs {
  display: flex;
  margin: 0 28rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #9E9EB0;
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #fff;
  font-weight: 600;
}

.opponents-list, .requests-list {
  padding: 0 28rpx;
}

.opponent-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.opponent-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.opponent-avatar-wrap {
  margin-right: 20rpx;
}

.opponent-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.opponent-avatar-fallback {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.opponent-info {
  flex: 1;
}

.opponent-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D3A;
  display: block;
  margin-bottom: 4rpx;
}

.opponent-rank {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
}

.match-score-badge {
  background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.1));
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
  text-align: center;
}

.match-score-val {
  font-size: 32rpx;
  font-weight: 800;
  color: #667EEA;
  display: block;
}

.match-score-label {
  font-size: 20rpx;
  color: #9E9EB0;
  display: block;
}

.challenge-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.challenge-btn::after { border: none; }

.challenge-btn:active { opacity: 0.8; }

.request-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.request-top {
  display: flex;
  align-items: center;
}

.request-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.request-info {
  flex: 1;
}

.request-target {
  font-size: 28rpx;
  color: #2D2D3A;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.request-status {
  font-size: 22rpx;
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.request-status.status-pending {
  background: rgba(245,166,35,0.12);
  color: #F5A623;
}

.request-status.status-accepted {
  background: rgba(52,199,89,0.12);
  color: #34C759;
}

.request-status.status-rejected,
.request-status.status-cancelled {
  background: rgba(158,158,176,0.12);
  color: #9E9EB0;
}

.request-message {
  font-size: 24rpx;
  color: #9E9EB0;
  margin-top: 12rpx;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #9E9EB0;
}
