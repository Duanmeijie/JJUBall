.page-wrap {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 60rpx;
}

.header-banner {
  background: linear-gradient(135deg, #D4363C 0%, #E85D5D 50%, #FF6B35 100%);
  padding: 60rpx 36rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.profile-mini {
  margin: -40rpx 28rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}

.avatar-round {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-letter {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D3A;
  display: block;
}

.profile-season {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-top: 4rpx;
}

.stats-row-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
  padding: 0 28rpx;
  margin-top: 28rpx;
}

.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stat-val {
  font-size: 44rpx;
  font-weight: 800;
  display: block;
  line-height: 1.2;
}

.accent-red { color: #D4363C; }
.accent-green { color: #34C759; }
.accent-orange { color: #FF6B35; }

.stat-lbl {
  font-size: 22rpx;
  color: #9E9EB0;
  display: block;
  margin-top: 6rpx;
}

.winrate-section {
  margin: 28rpx 28rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.winrate-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.winrate-l { font-size: 28rpx; color: #2D2D3A; font-weight: 600; }
.winrate-r { font-size: 36rpx; color: #D4363C; font-weight: 800; }

.winrate-bar-wrap {
  height: 14rpx;
  background: #F0F0F5;
  border-radius: 7rpx;
  overflow: hidden;
}

.winrate-fill {
  height: 100%;
  background: linear-gradient(90deg, #D4363C, #FF6B35, #F5A623);
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

.winrate-record {
  font-size: 22rpx;
  margin-top: 12rpx;
  display: block;
}

.score-section {
  margin: 28rpx 28rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.score-row {
  display: flex;
  gap: 20rpx;
}

.score-item {
  flex: 1;
  text-align: center;
}

.score-label {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-bottom: 6rpx;
}

.score-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #2D2D3A;
}

.credit-green { color: #34C759 !important; }
.credit-orange { color: #FF6B35 !important; }
.credit-red { color: #D4363C !important; }

.rank-progress {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F5;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rank-label {
  font-size: 24rpx;
  color: #9E9EB0;
  flex-shrink: 0;
}

.progress-track-sm {
  flex: 1;
  height: 10rpx;
  background: #F0F0F5;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill-sm {
  height: 100%;
  background: linear-gradient(90deg, #CD7F32, #9E9EB0, #F5A623, #D4363C);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.rank-percent {
  font-size: 22rpx;
  font-weight: 600;
  color: #D4363C;
  flex-shrink: 0;
}

.monthly-section {
  margin: 28rpx 28rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.section-header {
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D3A;
}

.monthly-chart {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  height: 260rpx;
  padding: 0 8rpx;
}

.month-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.bar-column {
  width: 100%;
  max-width: 48rpx;
  background: linear-gradient(180deg, #D4363C, #FF6B35);
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 8rpx;
  min-height: 20rpx;
  transition: height 0.5s ease;
}

.bar-count {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.bar-label {
  font-size: 20rpx;
  color: #9E9EB0;
  margin-top: 8rpx;
}

.empty-chart-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #9E9EB0;
  padding: 40rpx 0;
}

.opponent-section {
  margin: 28rpx 28rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.opponent-highlight {
  display: flex;
  align-items: center;
}

.opponent-emoji {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.opponent-info {}

.opponent-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2D3A;
  display: block;
}

.opponent-stat {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-top: 4rpx;
}

.recent-section {
  margin: 28rpx 28rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.recent-list {}

.recent-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F8;
}

.recent-item:last-child { border-bottom: none; }

.recent-result {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.recent-result.win { background: #34C759; }
.recent-result.lose { background: #D4363C; }

.recent-meta {
  font-size: 26rpx;
  color: #2D2D3A;
  font-weight: 500;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #9E9EB0;
}

.text-gray { color: #9E9EB0; }
