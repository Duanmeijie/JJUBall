.page-wrap {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 60rpx;
}

.header-banner {
  background: linear-gradient(135deg, #D4363C 0%, #E85D5D 50%, #FF6B35 100%);
  padding: 60rpx 36rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  display: block;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: -40rpx 28rpx 28rpx;
  position: relative;
  z-index: 2;
}

.stat-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.stat-card-1::before { background: linear-gradient(90deg, #D4363C, #FF6B35); }
.stat-card-2::before { background: linear-gradient(90deg, #667EEA, #764BA2); }
.stat-card-3::before { background: linear-gradient(90deg, #F5A623, #FF6B35); }
.stat-card-4::before { background: linear-gradient(90deg, #34C759, #2ECC71); }

.stat-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #2D2D3A;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-top: 6rpx;
}

.stat-unit {
  font-size: 20rpx;
  color: #9E9EB0;
  position: absolute;
  top: 30rpx;
  right: 24rpx;
}

.checkin-btn-wrap {
  padding: 0 28rpx;
  margin-bottom: 28rpx;
}

.checkin-btn {
  background: linear-gradient(135deg, #D4363C 0%, #FF6B35 100%);
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(212,54,60,0.3);
}

.checkin-btn.checked {
  background: linear-gradient(135deg, #34C759 0%, #2ECC71 100%);
  box-shadow: 0 8rpx 32rpx rgba(52,199,89,0.3);
}

.checkin-btn:active {
  transform: scale(0.97);
}

.checkin-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.checkin-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.progress-ring-section {
  margin: 0 28rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D3A;
  margin-bottom: 20rpx;
  display: block;
}

.progress-track {
  height: 16rpx;
  background: #F0F0F5;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill-grad {
  height: 100%;
  background: linear-gradient(90deg, #D4363C, #FF6B35, #F5A623);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #9E9EB0;
  margin-top: 12rpx;
  display: block;
  text-align: right;
}

.calendar-section {
  margin: 0 28rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.calendar-grid {
  width: 100%;
}

.calendar-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.cal-header-item {
  text-align: center;
  font-size: 24rpx;
  color: #9E9EB0;
  font-weight: 500;
  padding: 8rpx 0;
}

.calendar-body {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  aspect-ratio: 1;
}

.day-cell {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 72rpx;
}

.day-cell.today {
  background: rgba(212,54,60,0.1);
  border: 2rpx solid #D4363C;
}

.day-cell.checked {
  background: linear-gradient(135deg, #34C759, #2ECC71);
}

.day-cell.checked .day-num {
  color: #fff;
}

.day-cell.other-month .day-num {
  color: #ddd;
}

.day-num {
  font-size: 26rpx;
  color: #2D2D3A;
  font-weight: 500;
}

.day-check-mark {
  font-size: 16rpx;
  color: #fff;
  position: absolute;
  bottom: 6rpx;
}

.records-section {
  margin: 0 28rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F8;
}

.record-item:last-child { border-bottom: none; }

.record-left {
  display: flex;
  align-items: center;
}

.record-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.record-date {
  font-size: 28rpx;
  color: #2D2D3A;
  font-weight: 500;
  display: block;
}

.record-duration {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-top: 4rpx;
}

.record-notes {
  font-size: 24rpx;
  color: #9E9EB0;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #9E9EB0;
}
