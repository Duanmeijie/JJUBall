.page-wrap {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 60rpx;
}

.header-banner {
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 50%, #0F3460 100%);
  padding: 60rpx 36rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
}

.avg-score-card {
  margin: -40rpx 28rpx 28rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}

.avg-score-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A1A2E, #0F3460);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.avg-score-val {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  line-height: 1.1;
}

.avg-score-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.7);
  display: block;
}

.avg-score-info {
  flex: 1;
}

.info-line {
  font-size: 24rpx;
  color: #9E9EB0;
  display: block;
  margin-bottom: 4rpx;
}

.view-tabs {
  display: flex;
  margin: 0 28rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.view-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #9E9EB0;
  border-radius: 14rpx;
  font-weight: 500;
}

.view-tab.active {
  background: linear-gradient(135deg, #1A1A2E, #0F3460);
  color: #fff;
  font-weight: 600;
}

.radar-section {
  margin: 0 28rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex;
  justify-content: center;
}

.radar-canvas {
  width: 500rpx;
  height: 500rpx;
}

.badges-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 28rpx;
}

.badge-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.badge-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212,54,60,0.1), rgba(255,107,53,0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.badge-icon {
  font-size: 40rpx;
}

.badge-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D3A;
  display: block;
  margin-bottom: 4rpx;
}

.badge-desc {
  font-size: 22rpx;
  color: #9E9EB0;
  display: block;
}

.skills-section {
  padding: 0 28rpx;
}

.skill-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.skill-card:active {
  transform: scale(0.98);
}

.skill-header {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.skill-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.skill-name {
  flex: 1;
  font-size: 28rpx;
  color: #2D2D3A;
  font-weight: 500;
}

.skill-score {
  font-size: 32rpx;
  color: #D4363C;
}

.skill-bar {
  height: 10rpx;
  background: #F0F0F5;
  border-radius: 5rpx;
  overflow: hidden;
}

.skill-fill {
  height: 100%;
  background: linear-gradient(90deg, #D4363C, #FF6B35);
  border-radius: 5rpx;
  transition: width 0.5s ease;
}

.empty-tip {
  grid-column: 1 / -1;
  text-align: center;
  padding: 60rpx;
  font-size: 26rpx;
  color: #9E9EB0;
}

.assess-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: none;
  flex-direction: column;
  justify-content: flex-end;
}

.assess-panel.show {
  display: flex;
}

.panel-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
}

.panel-content {
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 60rpx 40rpx 80rpx;
  position: relative;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D3A;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}

.panel-skill {
  font-size: 36rpx;
  color: #D4363C;
  font-weight: 600;
  display: block;
  text-align: center;
  margin-bottom: 8rpx;
}

.panel-score {
  font-size: 60rpx;
  font-weight: 800;
  color: #D4363C;
  display: block;
  text-align: center;
  margin-bottom: 16rpx;
}

.panel-tips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.tip-item {
  font-size: 22rpx;
  color: #9E9EB0;
  background: #F5F5F8;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, #1A1A2E, #0F3460);
  color: #fff;
}

.btn-secondary {
  background: #F5F5F8;
  color: #9E9EB0;
}
