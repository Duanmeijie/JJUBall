.page-container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Current Season Card */
.current-season-card {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(67, 233, 123, 0.25);
}

.current-season-card.empty {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  box-shadow: none;
}

.empty-season-text {
  font-size: 28rpx;
  color: #999;
}

.season-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.season-badge.active {
  background-color: rgba(255, 255, 255, 0.3);
  color: #fff;
}

.season-card-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.season-date-range {
  margin-bottom: 20rpx;
}

.date-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.season-status {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-dot.active {
  background-color: #fff;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.8);
}

.status-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.view-ranking-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #07c160;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 36rpx;
  border: none;
  text-align: center;
  padding: 0;
}

.view-ranking-btn::after {
  border: none;
}

/* Admin Section */
.admin-section {
  margin-bottom: 30rpx;
}

.create-season-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: none;
}

.create-season-btn::after {
  border: none;
}

/* History Section */
.history-section {
  margin-top: 20rpx;
}

.section-header {
  padding: 20rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* Season List */
.season-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.season-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.season-item:last-child {
  border-bottom: none;
}

.season-item-left {
  display: flex;
  flex-direction: column;
}

.season-item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.season-item-date {
  font-size: 24rpx;
  color: #999;
}

.season-item-right {
  display: flex;
  align-items: center;
}

.season-archived-badge,
.season-ended-badge {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.season-archived-badge {
  background-color: #f0f0f0;
}

.season-archived-badge text {
  font-size: 22rpx;
  color: #999;
}

.season-ended-badge {
  background-color: #fff3e0;
}

.season-ended-badge text {
  font-size: 22rpx;
  color: #ff9800;
}

.item-arrow {
  font-size: 22rpx;
  color: #ccc;
}

/* Empty History */
.empty-history {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-history-text {
  font-size: 28rpx;
  color: #999;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}
