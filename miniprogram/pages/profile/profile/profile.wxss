/* pages/profile/profile/profile.wxss */
/* 国球红 Design System */

.profile-page {
  min-height: 100vh;
  background-color: #F5F5F8;
}

/* ==================== Profile Header ==================== */
.profile-header {
  background: linear-gradient(135deg, #D4363C 0%, #E85D5D 100%);
  padding: 80rpx 40rpx 100rpx;
  position: relative;
}

.header-content {
  display: flex;
  align-items: center;
}

/* Avatar */
.avatar-wrapper {
  flex-shrink: 0;
  margin-right: 28rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.avatar-fallback {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-letter {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* User Meta */
.user-meta {
  flex: 1;
}

.nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 14rpx;
}

.badges-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.role-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(4px);
}

.rank-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

/* ==================== Stats Dashboard Card ==================== */
.stats-card {
  margin: -60rpx 28rpx 28rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx 24rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
}

.stats-grid {
  display: flex;
  align-items: flex-start;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D2D3A;
  line-height: 1.2;
}

.rank-value {
  font-size: 30rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 22rpx;
  color: #9E9EB0;
  margin-top: 8rpx;
}

.stats-divider {
  height: 1rpx;
  background: #F0F0F5;
  margin: 28rpx 0 24rpx;
}

.stats-row-bottom {
  display: flex;
  align-items: center;
}

.stats-row-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.stats-row-label {
  font-size: 24rpx;
  color: #9E9EB0;
}

.stats-row-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D3A;
}

.stats-row-sep {
  width: 1rpx;
  height: 36rpx;
  background: #F0F0F5;
}

/* Credit score colors */
.credit-green {
  color: #52C41A !important;
}

.credit-orange {
  color: #FF6B35 !important;
}

.credit-red {
  color: #D4363C !important;
}

/* ==================== Menu Card ==================== */
.menu-card {
  margin: 0 28rpx 40rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx 32rpx;
  position: relative;
}

.menu-item::after {
  content: '';
  position: absolute;
  left: 80rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: #F5F5F8;
}

.menu-item:last-child::after {
  display: none;
}

.menu-item-hover {
  background-color: #F9F9FB;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  font-size: 30rpx;
  color: #2D2D3A;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-arrow {
  font-size: 28rpx;
  color: #C8C8D0;
  font-weight: 300;
}

/* Admin menu item */
.menu-text-admin {
  color: #D4363C;
  font-weight: 600;
}

.menu-arrow-admin {
  color: #D4363C;
}

/* Unread badge */
.unread-badge {
  font-size: 20rpx;
  color: #FFFFFF;
  background: #D4363C;
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 17rpx;
  padding: 0 10rpx;
  margin-right: 16rpx;
  font-weight: 500;
}

/* Menu divider (thick) */
.menu-divider {
  height: 16rpx;
  background: #F5F5F8;
}

/* ==================== Login State ==================== */
.login-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  background: #F5F5F8;
}

.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.login-emoji {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D3A;
  margin-bottom: 16rpx;
  text-align: center;
}

.login-desc {
  font-size: 26rpx;
  color: #9E9EB0;
  margin-bottom: 60rpx;
  text-align: center;
}

.login-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #D4363C 0%, #FF6B35 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  letter-spacing: 2rpx;
}

.login-btn::after {
  border: none;
}
