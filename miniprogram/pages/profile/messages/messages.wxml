<!-- pages/profile/messages/messages.wxml -->
<view class="messages-page">
  <!-- 消息列表 -->
  <block wx:if="{{messageList.length > 0}}">
    <view class="message-list">
      <view
        class="message-item {{item.isRead ? '' : 'unread'}}"
        wx:for="{{messageList}}"
        wx:key="_id"
        bindtap="onMessageTap"
        data-index="{{index}}"
      >
        <view class="message-icon-wrap">
          <image
            class="message-icon"
            src="{{item.type === 'system' ? '/static/images/icon-msg-system.png' : item.type === 'activity' ? '/static/images/icon-msg-activity.png' : '/static/images/icon-msg-match.png'}}"
          ></image>
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>
        <view class="message-content">
          <view class="message-header">
            <text class="message-title">{{item.title}}</text>
            <text class="message-time">{{item.relativeTime}}</text>
          </view>
          <text class="message-preview">{{item.content}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <view class="loading-more" wx:if="{{loading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="load-more-btn" wx:else bindtap="loadMore">
        <text class="load-more-text">加载更多</text>
      </view>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && messageList.length > 0}}">
      <text class="no-more-text">-- 没有更多消息 --</text>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && messageList.length === 0}}">
    <image class="empty-icon" src="/static/images/empty-message.png" mode="aspectFit"></image>
    <text class="empty-text">暂无消息</text>
    <text class="empty-desc">消息通知将显示在这里</text>
  </view>

  <!-- 初始加载 -->
  <view class="loading-container" wx:if="{{loading && messageList.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
