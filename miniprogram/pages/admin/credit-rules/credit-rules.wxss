.container {
  padding: 24rpx;
  background-color: #f5f6fa;
  min-height: 100vh;
}

/* Rules Card */
.rules-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* Rule Item */
.rule-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.rule-label {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.rule-value {
  display: flex;
  align-items: baseline;
}

.value-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #e53935;
  margin-right: 6rpx;
}

.value-unit {
  font-size: 24rpx;
  color: #999999;
}

.rule-input {
  width: 160rpx;
  height: 56rpx;
  border: 1rpx solid #1a73e8;
  border-radius: 8rpx;
  text-align: center;
  font-size: 28rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.rule-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

/* Notice Box */
.notice-box {
  background-color: #fff8e1;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  border-left: 6rpx solid #ffc107;
}

.notice-text {
  font-size: 24rpx;
  color: #795548;
  line-height: 1.6;
}

/* Action Buttons */
.action-bar {
  padding: 24rpx 0;
}

.btn {
  padding: 24rpx 0;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-edit {
  background-color: #1a73e8;
  color: #ffffff;
}

.btn-edit:active {
  opacity: 0.8;
}

.btn-group {
  display: flex;
  gap: 24rpx;
}

.btn-cancel {
  flex: 1;
  background-color: #f5f5f5;
  color: #666666;
}

.btn-cancel:active {
  background-color: #e0e0e0;
}

.btn-save {
  flex: 1;
  background-color: #1a73e8;
  color: #ffffff;
}

.btn-save:active {
  opacity: 0.8;
}

/* No Auth */
.no-auth {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
}

.no-auth-text {
  font-size: 32rpx;
  color: #999999;
}
