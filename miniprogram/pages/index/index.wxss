/* pages/index/index.wxss */

.page-container {
  min-height: 100vh;
  background: #F5F5F8;
  padding-bottom: 40rpx;
}

/* ========== Header Banner ========== */
.header-banner {
  background: linear-gradient(135deg, #D4363C 0%, #E85D5D 100%);
  padding: 80rpx 36rpx 100rpx;
  border-radius: 0 0 40rpx 40rpx;
  position: relative;
}

.banner-inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.banner-left {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.subtitle-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 400;
}

.banner-right {
  padding-top: 8rpx;
}

.bell-icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.bell-emoji {
  font-size: 36rpx;
}

.unread-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #FF6B35;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid #D4363C;
}

.badge-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 600;
  line-height: 1;
}

/* ========== Stats Card ========== */
.stats-card {
  margin: -60rpx 28rpx 0;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D2D3A;
  margin-bottom: 8rpx;
}

.stat-rank {
  font-size: 34rpx;
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  color: #6B6B80;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: #EDEDF0;
}

.winrate-bar {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F5;
}

.winrate-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.winrate-text {
  font-size: 24rpx;
  color: #6B6B80;
}

.winrate-value {
  font-size: 24rpx;
  color: #D4363C;
  font-weight: 600;
}

.winrate-track {
  height: 12rpx;
  background: #F0F0F5;
  border-radius: 6rpx;
  overflow: hidden;
}

.winrate-fill {
  height: 100%;
  background: linear-gradient(90deg, #D4363C, #FF6B35);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* ========== Quick Actions ========== */
.quick-actions-section {
  margin-top: 28rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 12rpx 12rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  padding: 16rpx 0 20rpx;
}

.action-item:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.action-emoji-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.action-emoji {
  font-size: 40rpx;
}

.action-bg-1 {
  background: linear-gradient(135deg, rgba(212, 54, 60, 0.1), rgba(212, 54, 60, 0.05));
}

.action-bg-2 {
  background: linear-gradient(135deg, rgba(245, 166, 35, 0.12), rgba(245, 166, 35, 0.05));
}

.action-bg-3 {
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.1), rgba(255, 107, 53, 0.05));
}

.action-bg-4 {
  background: linear-gradient(135deg, rgba(107, 107, 128, 0.1), rgba(107, 107, 128, 0.05));
}

.action-bg-5 {
  background: linear-gradient(135deg, rgba(156, 39, 176, 0.1), rgba(156, 39, 176, 0.05));
}

.action-bg-6 {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1), rgba(76, 175, 80, 0.05));
}

.action-label {
  font-size: 24rpx;
  color: #2D2D3A;
  font-weight: 500;
}

/* ========== Section Common ========== */
.section {
  margin: 0 28rpx 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D3A;
}

.section-more {
  display: flex;
  align-items: center;
}

.more-link {
  font-size: 26rpx;
  color: #6B6B80;
}

/* ========== Ranking Card ========== */
.ranking-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D3A;
}

.card-more {
  display: flex;
  align-items: center;
}

.top3-list {
  /* container for top 3 items */
}

.top3-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.top3-item:last-child {
  margin-bottom: 0;
}

.top3-item:first-child {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.08), rgba(255, 215, 0, 0.02));
}

.top3-item:nth-child(2) {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.1), rgba(192, 192, 192, 0.03));
}

.top3-item:nth-child(3) {
  background: linear-gradient(135deg, rgba(205, 127, 50, 0.08), rgba(205, 127, 50, 0.02));
}

.top3-left {
  display: flex;
  align-items: center;
}

.rank-medal {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.avatar-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-circle-0 {
  background: linear-gradient(135deg, #FFD700, #FFC107);
}

.avatar-circle-1 {
  background: linear-gradient(135deg, #C0C0C0, #B0BEC5);
}

.avatar-circle-2 {
  background: linear-gradient(135deg, #CD7F32, #D4A574);
}

.avatar-initial {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.top3-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D2D3A;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top3-right {
  display: flex;
  align-items: baseline;
}

.top3-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #D4363C;
}

.top3-unit {
  font-size: 22rpx;
  color: #6B6B80;
  margin-left: 4rpx;
}

/* ========== Activity List ========== */
.activity-list {
  /* wrapper for activity cards */
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  background: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.empty-text {
  font-size: 28rpx;
  color: #6B6B80;
}
